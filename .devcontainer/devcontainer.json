{
    "name": "Django Live API Monitoring",
    "image": "ghcr.io/astral-sh/uv:python3.14-trixie",
    "containerEnv": {
        "UV_LINK_MODE": "copy"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python", // Python language support
                "batisteo.vscode-django", // Django template snippets/syntax
                "bradlc.vscode-tailwindcss", // Tailwind CSS IntelliSense
                "charliermarsh.ruff" // Ultra-fast linting/formatting
            ],
            "settings": {
                "python.defaultInterpreterPath": "${workspaceFolder}/app/.venv/bin/python",
                "python.terminal.activateEnvInCurrentTerminal": true,
                "editor.formatOnSave": true,
                "files.autoSave": "afterDelay",
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff"
                },
                "python.analysis.extraPaths": [
                    "${workspaceFolder}/app"
                ]
            }
        }
    },
    "postCreateCommand": "cd app && uv sync"
}